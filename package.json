{
  "name": "@lunarity/nebula-fetch-cli",
  "version": "0.0.3",
  "description": "CLI tool for downloading media from different platforms",
  "type": "module",
  "main": "dist/index.cjs",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/turndown": "^5.0.6",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cheerio": "^1.2.0",
    "commander": "^12.1.0",
    "debug": "^4.4.3",
    "turndown": "^7.2.2",
    "youtube-dl-exec": "^3.0.30"
  },
  "bin": {
    "nebula-fetch": "./dist/index.cjs"
  },
  "scripts": {
    "build": "tsup && chmod +x ./dist/index.cjs",
    "dev": "tsx index.ts",
    "prepublish": "pnpm run build"
  },
  "keywords": [
    "cli",
    "media",
    "download",
    "youtube"
  ],
  "author": "Krzysztof Oszczapiński",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LUNARITYai/nebula-fetch-cli.git"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "youtube-dl-exec"
    ]
  }
}